generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  LECTURER
  STUDENT
}

enum Platform {
  IOS
  ANDROID
}

enum SemesterStatus {
  UPCOMING
  ENROLLMENT
  ONGOING
  COMPLETED
}

enum RoomType {
  THEORY
  LAB
}

enum SubjectType {
  GENERAL
  DEPARTMENT
}

enum StudentStatus {
  ACTIVE
  RESERVATION
  SUSPENDED
  GRADUATED
  DROPPED_OUT
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  EXCUSED
  LATE
}

enum GradeStatus {
  DRAFT
  SUBMITTED
}

enum AnnouncementScope {
  ALL
  DEPARTMENT
  CLASS
  SECTION
  SEMESTER
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  fullName     String
  role         Role
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  admin         Admin?
  student       Student?
  lecturer      Lecturer?
  refreshTokens RefreshToken[]
  deviceTokens  DeviceToken[]
  notifications Notification[]
  auditLogs     AuditLog[]
  announcements Announcement[] @relation("AnnouncementCreatedBy")
}

model Admin {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Department {
  id   Int    @id @default(autoincrement())
  code String @unique
  name String

  majors        Major[]
  classGroups   ClassGroup[]
  students      Student[]
  lecturers     Lecturer[]
  subjects      Subject[]
  announcements Announcement[]
  curriculum    Curriculum?
}

model Major {
  id           Int    @id @default(autoincrement())
  code         String @unique
  name         String
  departmentId Int

  department    Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  classGroups   ClassGroup[]
  students      Student[]

  @@index([departmentId])
}

model ClassGroup {
  id           Int    @id @default(autoincrement())
  code         String @unique
  name         String
  departmentId Int
  majorId      Int

  department    Department     @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  major         Major          @relation(fields: [majorId], references: [id], onDelete: Restrict)
  students      Student[]
  sections      Section[]
  announcements Announcement[]

  @@map("classes")
}

model Student {
  id           Int           @id @default(autoincrement())
  userId       Int           @unique
  studentCode  String        @unique
  departmentId Int
  majorId      Int
  classGroupId Int
  curriculumId Int?
  phone        String?
  address      String?
  status       StudentStatus @default(ACTIVE)

  currentSemester Int @default(1)

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  department          Department           @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  major               Major                @relation(fields: [majorId], references: [id], onDelete: Restrict)
  classGroup          ClassGroup           @relation(fields: [classGroupId], references: [id], onDelete: Restrict)
  curriculum          Curriculum?          @relation(fields: [curriculumId], references: [id], onDelete: Restrict)
  enrollments           Enrollment[]
  tuitionFees           TuitionFee[]
  paymentTransactions   PaymentTransaction[]
  attendances           Attendance[]
  examRegistrations     ExamRegistration[]

  @@index([classGroupId])
  @@index([departmentId])
  @@index([majorId])
  @@index([curriculumId])
}

model Lecturer {
  id           Int     @id @default(autoincrement())
  userId       Int     @unique
  lecturerCode String  @unique
  departmentId Int
  title        String?

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  department          Department           @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  teachingAssignments TeachingAssignment[]

  @@index([departmentId])
}

model Subject {
  id           Int         @id @default(autoincrement())
  code         String      @unique
  name         String
  credits      Int
  type         SubjectType @default(DEPARTMENT)
  departmentId Int?

  department         Department?         @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  sections           Section[]
  curriculumSubjects CurriculumSubject[]

  @@index([departmentId])
}

model Curriculum {
  id             Int      @id @default(autoincrement())
  departmentId   Int      @unique
  name           String
  totalSemesters Int      @default(8)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  department Department          @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  subjects   CurriculumSubject[]
  students   Student[]
}

model CurriculumSubject {
  id           Int @id @default(autoincrement())
  curriculumId Int
  subjectId    Int
  semester     Int

  curriculum Curriculum @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  subject    Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([curriculumId, subjectId])
  @@index([curriculumId, semester])
}

model Section {
  id           Int    @id @default(autoincrement())
  code         String @unique
  subjectId    Int
  semesterId   Int
  classGroupId Int?
  capacity     Int    @default(40)

  subject             Subject              @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  semester            Semester             @relation(fields: [semesterId], references: [id], onDelete: Restrict)
  classGroup          ClassGroup?          @relation(fields: [classGroupId], references: [id], onDelete: SetNull)
  teachingAssignments TeachingAssignment[]
  enrollments         Enrollment[]
  schedules           Schedule[]
  exams               Exam[]
  announcements       Announcement[]
  attendances         Attendance[]

  @@index([subjectId])
  @@index([semesterId])
  @@index([classGroupId])
}

model TeachingAssignment {
  id         Int      @id @default(autoincrement())
  sectionId  Int
  lecturerId Int
  createdAt  DateTime @default(now())

  section  Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  lecturer Lecturer @relation(fields: [lecturerId], references: [id], onDelete: Cascade)

  @@unique([sectionId, lecturerId])
  @@index([lecturerId])
}

model Enrollment {
  id                  Int      @id @default(autoincrement())
  sectionId           Int
  studentId           Int
  enrollmentDate      DateTime @default(now())
  isEligibleForExam   Boolean? // null = auto-calculate, true/false = manual override

  section         Section          @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  student         Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  grade           Grade?
  tuitionFeeItems TuitionFeeItem[]

  @@unique([sectionId, studentId])
  @@index([studentId])
}

model Grade {
  id           Int         @id @default(autoincrement())
  enrollmentId Int         @unique
  finalScore   Float?
  gpaPoint     Float?
  status       GradeStatus @default(DRAFT)
  submittedAt  DateTime?
  updatedAt    DateTime    @updatedAt

  enrollment Enrollment       @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  components GradeComponent[]
}

model GradeComponent {
  id      Int    @id @default(autoincrement())
  gradeId Int
  name    String
  weight  Float
  score   Float

  grade Grade @relation(fields: [gradeId], references: [id], onDelete: Cascade)

  @@index([gradeId])
}

model Schedule {
  id        Int       @id @default(autoincrement())
  sectionId Int
  roomId    Int?
  dayOfWeek Int
  shift     Int?
  startTime String?
  endTime   String?
  weekStart DateTime?
  createdAt DateTime  @default(now())

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  room    Room?   @relation(fields: [roomId], references: [id], onDelete: SetNull)

  @@index([sectionId])
  @@index([roomId])
}

model Exam {
  id        Int      @id @default(autoincrement())
  sectionId Int
  roomId    Int?
  examDate  DateTime
  type      String

  section             Section              @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  room                Room?                @relation(fields: [roomId], references: [id], onDelete: SetNull)
  examRegistrations   ExamRegistration[]

  @@index([sectionId])
  @@index([roomId])
}

model ExamRegistration {
  id               Int      @id @default(autoincrement())
  examId           Int
  studentId        Int
  registrationDate DateTime @default(now())

  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId])
  @@index([studentId])
}

model Announcement {
  id           Int               @id @default(autoincrement())
  title        String
  content      String
  scope        AnnouncementScope
  departmentId Int?
  classGroupId Int?
  sectionId    Int?
  semesterId   Int?
  createdById  Int
  createdAt    DateTime          @default(now())

  department    Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  classGroup    ClassGroup?    @relation(fields: [classGroupId], references: [id], onDelete: SetNull)
  section       Section?       @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  semester      Semester?      @relation(fields: [semesterId], references: [id], onDelete: SetNull)
  createdBy     User           @relation("AnnouncementCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  notifications Notification[]

  @@index([createdAt])
}

model Notification {
  id             Int      @id @default(autoincrement())
  userId         Int
  announcementId Int?
  title          String
  body           String
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  announcement Announcement? @relation(fields: [announcementId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model DeviceToken {
  id         Int      @id @default(autoincrement())
  userId     Int
  token      String   @unique
  platform   Platform
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

model TuitionFee {
  id         Int      @id @default(autoincrement())
  studentId  Int
  semesterId Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  student             Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  semester            Semester             @relation(fields: [semesterId], references: [id], onDelete: Restrict)
  items               TuitionFeeItem[]
  paymentTransactions PaymentTransaction[]

  @@unique([studentId, semesterId])
  @@index([studentId])
  @@index([semesterId])
}

model TuitionFeeItem {
  id           Int       @id @default(autoincrement())
  tuitionFeeId Int
  enrollmentId Int?
  name         String
  credits      Int       @default(0)
  creditPrice  Float     @default(0)
  amountDue    Float     @default(0)
  amountPaid   Float     @default(0)
  discount     Float     @default(0)
  debt         Float     @default(0)
  paidAt       DateTime?

  tuitionFee TuitionFee  @relation(fields: [tuitionFeeId], references: [id], onDelete: Cascade)
  enrollment Enrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)

  @@index([tuitionFeeId])
  @@index([enrollmentId])
}

model TuitionConfig {
  id          Int      @id @default(autoincrement())
  semesterId  Int      @unique
  creditPrice Float    @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  semester Semester @relation(fields: [semesterId], references: [id], onDelete: Cascade)
}

model Semester {
  id           Int            @id @default(autoincrement())
  name         String
  academicYear String
  startDate    DateTime
  endDate      DateTime
  status       SemesterStatus @default(UPCOMING)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  sections       Section[]
  tuitionFees    TuitionFee[]
  tuitionConfigs TuitionConfig[]
  announcements  Announcement[]
}

model Room {
  id       Int      @id @default(autoincrement())
  name     String   @unique
  capacity Int      @default(40)
  type     RoomType @default(THEORY)

  schedules Schedule[]
  exams     Exam[]
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

model PaymentTransaction {
  id             Int           @id @default(autoincrement())
  studentId      Int
  tuitionFeeId   Int
  txnRef         String        @unique
  amount         Float
  orderInfo      String
  vnpTxnNo       String?
  bankCode       String?
  payDate        String?
  status         PaymentStatus @default(PENDING)
  vnpResponseCode String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tuitionFee TuitionFee @relation(fields: [tuitionFeeId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([tuitionFeeId])
  @@index([txnRef])
  @@index([status])
}

model Attendance {
  id        Int              @id @default(autoincrement())
  sectionId Int
  studentId Int
  date      DateTime
  status    AttendanceStatus
  note      String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sectionId, studentId, date])
  @@index([sectionId])
  @@index([studentId])
}
