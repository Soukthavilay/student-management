{
  "name": "student-management-app",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "backend",
    "web-admin",
    "mobile"
  ],
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "backend:setup": "npm run prisma:generate --workspace backend && npm run prisma:push --workspace backend && npm run prisma:seed --workspace backend",
    "dev:backend": "npm run dev --workspace backend",
    "dev:web": "npm run dev --workspace web-admin",
    "dev:mobile": "npm start --workspace mobile",
    "test:backend": "npm run test --workspace backend"
  }
}
